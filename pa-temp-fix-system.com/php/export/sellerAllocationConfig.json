  "salesThreshold": {
    "_comment": "销量与毛利阈值配置。结果表不再单独落 sold30d / sold60d / marginValue 固定字段，改为把实际判定值写入 ruleSnapshot.evaluation。flowRules 优先使用 metrics 数组表达任意窗口天数和阈值；下方 salesThreshold 仅保留公共说明和可复用口径。",
    "dataMissingPolicy": "FAIL",
    "divideByZeroPolicy": "NULL",
    "marginCalculation": "SALE_AMOUNT_DIV_SALE_COUNT",
    "zeroSoldRelistRule": {
      "_comment": "PRD 中的30天零销量重刊规则保留在这里。当前主分流流程未直接消费这条规则，但文档层面先保留定义。",
      "enabled": true,
      "productLevel": "S级",
      "listingMode": "DIRECT",
      "listingDaysOperator": "GTE",
      "listingDaysValue": 30,
      "metrics": [
        {
          "type": "sold",
          "windowDays": 30,
          "operator": "EQ",
          "value": 0
        }
      ]
    },
    "metricDslExample": {
      "type": "sold",
      "windowDays": 30,
      "operator": "EQ",
      "value": 0,
      "_comment": "支持 sold / sale / pl / margin；windowDays 可配置 15/30/60/90 等任意天数"
    },
    "queryMetricWindows": [
      15,
      30,
      60,
      90
    ],
    "metricDslExamples": [
      {
        "type": "sold",
        "windowDays": 15,
        "operator": "EQ",
        "value": 0
      },
      {
        "type": "sold",
        "windowDays": 60,
        "operator": "GTE",
        "value": 0
      },
      {
        "type": "margin",
        "windowDays": 60,
        "operator": "GT",
        "value": 0
      }
    ]
  },
  "flowRules": {
    "_comment": "流程规则入口。优先使用 metrics 数组表达任意窗口天数和阈值判断；旧的 soldMetric / marginMetric 字段仅用于兼容历史配置。",
    "targetedSLevelLocalScu": {
      "_comment": "专项渠道开发 + S级：直接创建S号，并分配本土海外仓账号。",
      "enabled": true,
      "developmentMode": "TARGETED",
      "productLevels": [
        "S级"
      ],
      "resultRegionType": "LOCAL",
      "resultStage": "WAREHOUSE",
      "action": "CREATE_SCU_AND_ASSIGN_LOCAL_WAREHOUSE"
    },
    "targetedSListingDaysOver30": {
      "_comment": "专项渠道开发 + S级 + 上架天数超过30天：这里只做门槛判断，用于决定是否继续判断30天销量。",
      "enabled": true,
      "developmentModes": [
        "TARGETED"
      ],
      "productLevels": [
        "S级"
      ],
      "listingDaysOperator": "GT",
      "listingDaysValue": 30
    },
    "targetedSOver30ZeroSoldCreateGreaterChina": {
      "_comment": "专项渠道开发 + S级 + 上架天数超过30天 + 30天 sold=0：创建大中华区S号并分配账号。",
      "enabled": true,
      "developmentModes": [
        "TARGETED"
      ],
      "productLevels": [
        "S级"
      ],
      "listingDaysOperator": "GT",
      "listingDaysValue": 30,
      "resultRegionType": "GREATER_CHINA",
      "resultStage": "WAREHOUSE",
      "action": "CREATE_SCU_AND_ASSIGN_GREATER_CHINA_WAREHOUSE",
      "metrics": [
        {
          "type": "sold",
          "windowDays": 30,
          "operator": "EQ",
          "value": 0
        }
      ]
    },
    "targetedSOver30ArrivalCheck": {
      "_comment": "专项渠道开发 + S级 + 上架天数超过30天，但30天 sold 不等于0：进入海外仓到货检查流程。",
      "enabled": true,
      "developmentModes": [
        "TARGETED"
      ],
      "productLevels": [
        "S级"
      ],
      "listingDaysOperator": "GT",
      "listingDaysValue": 30,
      "resultRegionType": "GREATER_CHINA",
      "resultStage": "WAREHOUSE",
      "resultStatus": "WAIT_STOCK_CHECK",
      "action": "CHECK_OVERSEA_ARRIVAL_AND_SWITCH_A_SELLER"
    },
    "nonTargetedOrABLevelGreaterChinaScu": {
      "_comment": "非专项开发，或专项但不属于“专项S走本土仓”场景时，满足60天销量/毛利条件后，创建S号并分配大中华海外仓账号。",
      "enabled": true,
      "developmentModes": [
        "NON_TARGETED",
        "TARGETED"
      ],
      "productLevels": [
        "S级",
        "A级",
        "B级"
      ],
      "excludeWhen": {
        "developmentMode": "TARGETED",
        "productLevels": [
          "S级"
        ]
      },
      "resultRegionType": "GREATER_CHINA",
      "resultStage": "WAREHOUSE",
      "action": "CREATE_SCU_AND_ASSIGN_GREATER_CHINA_WAREHOUSE",
      "metrics": [
        {
          "type": "sold",
          "windowDays": 60,
          "operator": "GTE",
          "value": 0
        },
        {
          "type": "margin",
          "windowDays": 60,
          "operator": "GTE",
          "value": 0.15
        }
      ]
    },
    "defaultGreaterChinaScu": {
      "_comment": "默认兜底规则。前面都不命中时，失败入库等待轮询，直到满足条件。",
      "enabled": true,
      "resultRegionType": "GREATER_CHINA",
      "resultStage": "WAREHOUSE",
      "resultStatus": "FAILED_RETRYABLE",
      "action": "PERSIST_AND_POLL"
    }
  },
  "arrivalRules": {
    "_comment": "海外仓到货检查规则。当前代码会在 WAIT_STOCK_CHECK 场景下优先走 CETS SOAP 库存接口 getStockInventoryBySkuIdListAndStockIdList 判断是否已到仓；channelStockMappings 是渠道默认仓映射，若 accountMappings 单条规则本身配置了 warehouseStockCode / warehouseStockId，则优先使用单条规则配置。",
    "enabled": true,
    "dataSource": "cets_stock_inventory_soap",
    "channelStockMappings": {
      "ebay_us": {
        "stockCode": "US_04",
        "stockId": "15"
      },
      "ebay_uk": {
        "stockCode": "UK_06",
        "stockId": "70"
      },
      "ebay_au": {
        "stockCode": "AU_06",
        "stockId": "73"
      },
      "ebay_de": {
        "stockCode": "",
        "stockId": ""
      }
    },
    "arrivedResult": "SWITCH_TO_WAREHOUSE_SELLER",
    "notArrivedResult": "POLLING_POOL",
    "manualTransferApplyRequired": true,
    "skipAutoCreateTransferApplyWhenMissing": true
  },
  "historyCheck": {
    "_comment": "历史检查配置。用于从指定时间起回扫旧SKU，并决定默认是否 dryRun。",
    "enabled": true,
    "createdFrom": "2026-01-01T00:00:00+08:00",
    "defaultDryRun": true,
    "autoAllocateEnabled": false
  },
  "retryPolicy": {
    "_comment": "失败重试策略。仅适用于瞬时性错误，例如DBAPI超时、网络波动、下游服务不可用。",
    "enabled": true,
    "maxRetryCount": 3,
    "retryIntervalMinutes": [
      5,
      30,
      120
    ],
    "scanBatchSize": 200,
    "retryableFailureCodes": [
      "DBAPI_TIMEOUT",
      "NETWORK_ERROR",
      "DOWNSTREAM_UNAVAILABLE",
      "DATABASE_TRANSIENT_ERROR",
      "MQ_TRANSIENT_ERROR"
    ]
  },
  "workflow": {
    "_comment": "运行时流程编排配置。按 sourceType 选择流程图，节点顺序遍历执行；CONDITION 负责分支判断，ACTION 负责产生一步业务动作，END 负责返回最终态。",
    "version": "2026-06-25",
    "flows": {
      "seller_assign": {
        "_comment": "A号直发仓账号分配。先检查账号映射是否存在，再执行分配动作。",
        "flowStart": "accountMappingCheck",
        "nodes": {
          "accountMappingCheck": {
            "type": "CONDITION",
            "mode": "ACCOUNT_MAPPING_CHECK",
            "onPass": "assignDirectSeller",
            "onReject": "endNoAccount"
          },
          "assignDirectSeller": {
            "type": "ACTION",
            "action": "ASSIGN_DIRECT_SELLER",
            "next": "end"
          },
          "end": {
            "type": "END",
            "result": "SUCCESS"
          },
          "endNoAccount": {
            "type": "END",
            "result": "SKIPPED",
            "message": "账号映射未命中，无可用账号，不做结果入库"
          }
        }
      },
      "sku_upload": {
        "_comment": "A号上传后的流程编排。先检查账号映射是否存在，再执行分流规则判断。",
        "flowStart": "accountMappingCheck",
        "nodes": {
          "accountMappingCheck": {
            "type": "CONDITION",
            "mode": "ACCOUNT_MAPPING_CHECK",
            "onPass": "preCheck",
            "onReject": "endNoAccount"
          },
          "preCheck": {
            "type": "CONDITION",
            "mode": "PRE_RULE",
            "allowRules": [
              "targetedSLevelLocalScu",
              "nonTargetedOrABLevelGreaterChinaScu"
            ],
            "onPass": "targetedLocalBranch",
            "onReject": "endSkip"
          },
          "targetedLocalBranch": {
            "type": "CONDITION",
            "mode": "RULE",
            "rule": "targetedSLevelLocalScu",
            "onPass": "createLocalScu",
            "onReject": "greaterChinaBranch"
          },
          "createLocalScu": {
            "type": "ACTION",
            "rule": "targetedSLevelLocalScu",
            "action": "CREATE_SCU_AND_ASSIGN_LOCAL_WAREHOUSE",
            "next": "targetedListingDaysCheck"
          },
          "targetedListingDaysCheck": {
            "type": "CONDITION",
            "mode": "RULE",
            "rule": "targetedSListingDaysOver30",
            "onPass": "targetedZeroSoldCheck",
            "onReject": "failAndPoll"
          },
          "targetedZeroSoldCheck": {
            "type": "CONDITION",
            "mode": "RULE",
            "rule": "targetedSOver30ZeroSoldCreateGreaterChina",
            "onPass": "createGreaterChinaScuByZeroSold",
            "onReject": "arrivalCheck"
          },
          "createGreaterChinaScuByZeroSold": {
            "type": "ACTION",
            "rule": "targetedSOver30ZeroSoldCreateGreaterChina",
            "action": "CREATE_SCU_AND_ASSIGN_GREATER_CHINA_WAREHOUSE",
            "next": "endSuccess"
          },
          "arrivalCheck": {
            "type": "ACTION",
            "rule": "targetedSOver30ArrivalCheck",
            "action": "CHECK_OVERSEA_ARRIVAL_AND_SWITCH_A_SELLER",
            "next": "endSuccess"
          },
          "greaterChinaBranch": {
            "type": "CONDITION",
            "mode": "RULE",
            "rule": "nonTargetedOrABLevelGreaterChinaScu",
            "onPass": "createGreaterChinaScu",
            "onReject": "failAndPoll"
          },
          "createGreaterChinaScu": {
            "type": "ACTION",
            "rule": "nonTargetedOrABLevelGreaterChinaScu",
            "action": "CREATE_SCU_AND_ASSIGN_GREATER_CHINA_WAREHOUSE",
            "next": "endSuccess"
          },
          "failAndPoll": {
            "type": "ACTION",
            "action": "PERSIST_AND_POLL",
            "resultStatus": "FAILED_RETRYABLE",
            "next": "endFailed"
          },
          "endFailed": {
            "type": "END",
            "result": "FAILED_RETRYABLE",
            "message": "未满足上架天数或后续业务条件，失败入库等待轮询"
          },
          "endSkip": {
            "type": "END",
            "result": "SKIPPED",
            "message": "未命中专项开发+产品分级前置规则，直接返回"
          },
          "endNoAccount": {
            "type": "END",
            "result": "SKIPPED",
            "message": "账号映射未命中，无可用账号，不做结果入库"
          },
          "endSuccess": {
            "type": "END",
            "result": "SUCCESS"
          }
        }
      }
    }
  }
}